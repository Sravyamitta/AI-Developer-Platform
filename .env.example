# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_dev_platform
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_dev_platform

# GitHub OAuth App
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_WEBHOOK_SECRET=your_webhook_secret
# Public URL for webhook delivery (use ngrok in local dev)
WEBHOOK_BASE_URL=https://your-ngrok-url.ngrok.io

# Anthropic (for AI features)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Embeddings — choose one provider
EMBEDDING_PROVIDER=voyage           # "voyage" (recommended) or "openai"
VOYAGE_API_KEY=your_voyage_api_key  # https://dash.voyageai.com
OPENAI_API_KEY=your_openai_api_key  # only needed if EMBEDDING_PROVIDER=openai

# JWT
JWT_SECRET=your_jwt_secret_min_32_chars

# Service ports
API_GATEWAY_PORT=3001
GITHUB_SERVICE_PORT=3002
AI_SERVICE_PORT=3003
EMBEDDINGS_SERVICE_PORT=3004
REPO_QA_SERVICE_PORT=3005

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:3001
