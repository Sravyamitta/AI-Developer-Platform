# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_dev_platform
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_dev_platform

# GitHub OAuth App
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_WEBHOOK_SECRET=your_webhook_secret
# Public URL for webhook delivery (use ngrok in local dev)
WEBHOOK_BASE_URL=https://your-ngrok-url.ngrok.io

# Google Gemini (AI + Embeddings)
# Get free API key at: aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key

# Embeddings provider: "gemini" (free), "voyage", or "openai"
EMBEDDING_PROVIDER=gemini

# JWT
JWT_SECRET=your_jwt_secret_min_32_chars

# Service ports
API_GATEWAY_PORT=3001
GITHUB_SERVICE_PORT=3002
AI_SERVICE_PORT=3003
EMBEDDINGS_SERVICE_PORT=3004
REPO_QA_SERVICE_PORT=3005

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:3001
