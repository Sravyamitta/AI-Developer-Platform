{
  "name": "ai-developer-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "docker-compose up --build",
    "dev:web": "yarn workspace web dev",
    "dev:api": "yarn workspace api-gateway dev",
    "dev:github": "yarn workspace github-service dev",
    "dev:ai": "yarn workspace ai-service dev",
    "dev:embeddings": "yarn workspace embeddings-service dev",
    "dev:qa": "yarn workspace repo-qa-service dev",
    "build": "yarn workspaces run build",
    "lint": "yarn workspaces run lint",
    "typecheck": "yarn workspaces run typecheck"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  },
  "packageManager": "yarn@1.22.21"
}
